{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=litellm;Username=user;Password=password"
  },
  "LlmConfig": {
    "DefaultProvider": "openai",
    "Providers": {
      "ollama": { "BaseUrl": "http://localhost:11434", "Prefix": "ollama/" },
      "vllm": { "BaseUrl": "http://localhost:8000", "Prefix": "vllm/" },
      "openai": { "BaseUrl": "https://api.openai.com/v1", "ApiKey": "${OPENAI_API_KEY}", "Prefix": "openai/" },
      "openrouter": { "BaseUrl": "https://openrouter.ai/api/v1", "ApiKey": "${OPENROUTER_API_KEY}", "Prefix": "openrouter/" },
      "zai": { "BaseUrl": "https://api.z.ai/v1", "ApiKey": "${ZAI_API_KEY}", "Prefix": "zai/" }
    }
  },
  "AllowedHosts": "*"
}